;; Bun runtime and package manager
;;
;; Bun installs to ~/.bun/bin/bun via its install script.
;; Package cache lives at ~/.bun/install/.
;; bunx (like npx) downloads and executes from the cache.

;; Exec — bun binary and cached packages (bunx runs from cache)
(allow process-exec
  (subpath (string-append (param "HOME") "/.bun")))

;; Read — binary, cache, config
(allow file-read-data
  (subpath (string-append (param "HOME") "/.bun")))

;; Write — install cache only. ~/.bun/bin is not writable to
;; prevent overwriting the bun binary itself.
(allow file-write*
  (subpath (string-append (param "HOME") "/.bun/install")))
