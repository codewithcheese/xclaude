;; pnpm package manager
;; Provides: pnpm binary, global store, dlx execution, config

;; Exec — pnpm binary and store (dlx executes packages from the store)
(allow process-exec
  (subpath (string-append (param "HOME") "/.local/share/pnpm"))
  (subpath (string-append (param "HOME") "/.pnpm-store")))

;; Read — binary, config, and global store
(allow file-read-data
  (subpath (string-append (param "HOME") "/.local/share/pnpm"))
  (subpath (string-append (param "HOME") "/.pnpm-store"))
  (subpath (string-append (param "HOME") "/Library/Preferences/pnpm"))
  (subpath (string-append (param "HOME") "/.config/pnpm")))

;; Write — global store (content-addressable cache, dlx temp packages)
(allow file-write*
  (subpath (string-append (param "HOME") "/.pnpm-store")))
