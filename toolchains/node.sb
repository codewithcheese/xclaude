;; Node.js toolchain (NVM + npm + npx)
;; Provides: node, npm, npx via NVM; npm cache writes

;; Exec — NVM-managed node/npm/npx binaries AND npm cache
;; npx downloads packages to ~/.npm/_npx/ and executes from there
(allow process-exec
  (subpath (string-append (param "HOME") "/.nvm"))
  (subpath (string-append (param "HOME") "/.npm")))

(allow file-read-data
  (subpath (string-append (param "HOME") "/.nvm"))
  (subpath (string-append (param "HOME") "/.npm")))

(allow file-write*
  (subpath (string-append (param "HOME") "/.npm")))
